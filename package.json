{
  "name": "unigen",
  "description": "film generator",
  "version": "0.0.3",
  "type": "module",
  "author": {
    "email": "masol.li@gmail.com",
    "name": "lizhutang",
    "url": "https://lizt.top"
  },
  "main": "packages/entry-point.mjs",
  "packageManager": "pnpm@11.5.2",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "preinstall": "npx only-allow pnpm",
    "db:generate": "drizzle-kit generate --config=drizzle.config.ts",
    "build": "pnpm -r --if-present run build",
    "compile": "pnpm run build && electron-builder build --config electron-builder.mjs -p never",
    "test": "pnpm exec playwright test ./tests/e2e.spec.ts",
    "start": "node packages/dev-mode.js",
    "typecheck": "pnpm -r --if-present run typecheck",
    "renderer:add": "pnpm --dir packages/renderer add"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@npmcli/map-workspaces": "5.0.3",
    "@playwright/test": "1.58.2",
    "@types/node": "25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "drizzle-kit": "^0.31.10",
    "drizzle-orm": "^0.45.2",
    "electron": "^41.0.3",
    "electron-builder": "26.8.1",
    "esbuild": "^0.28.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-svelte": "^3.19.0",
    "glob": "13.0.6",
    "playwright": "^1.58.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "vite": "^8.0.16",
    "@app/preload": "workspace:*"
  },
  "dependencies": {
    "@app/main": "workspace:*"
  },
  "allowScripts": {
    "electron@41.0.3": true,
    "electron-winstaller@5.4.0": true,
    "globals": true
  }
}