{
  "name": "ugvideo",
  "description": "film generator",
  "version": "0.0.3",
  "type": "module",
  "author": {
    "email": "masol.li@gamil.com",
    "name": "lizhutang",
    "url": "https://lizt.top"
  },
  "main": "packages/entry-point.mjs",
  "workspaces": [
    "packages/*"
  ],
  "engines": {
    "node": ">=23.0.0"
  },
  "scripts": {
    "build": "npm run build -ws --if-present",
    "compile": "npm run build && electron-builder build --config electron-builder.mjs",
    "test": "npx playwright test ./tests/e2e.spec.ts",
    "start": "node packages/dev-mode.js",
    "typecheck": "npm run typecheck -ws --if-present",
    "renderer:add": "npm run add --workspace @app/renderer"
  },
  "devDependencies": {
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@npmcli/map-workspaces": "5.0.3",
    "@playwright/test": "1.58.2",
    "@types/node": "25.9.3",
    "@typescript-eslint/eslint-plugin": "^8.61.0",
    "@typescript-eslint/parser": "^8.61.0",
    "create-vite": "9.0.7",
    "electron": "41.0.3",
    "electron-builder": "26.8.1",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-svelte": "^3.19.0",
    "glob": "13.0.6",
    "playwright": "^1.58.2",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "@app/main": "*"
  },
  "allowScripts": {
    "electron@41.0.3": true,
    "electron-winstaller@5.4.0": true,
    "globals": true
  }
}
