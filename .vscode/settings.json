{
  "editor.codeActionsOnSave": {
    "source.fixAll.eslint": "explicit",
    "source.organizeImports": "explicit"
  },
  "workbench.colorCustomizations": {
    "activityBar.activeBackground": "#ff6433",
    "activityBar.background": "#ff6433",
    "activityBar.foreground": "#15202b",
    "activityBar.inactiveForeground": "#15202b99",
    "activityBarBadge.background": "#00ff3d",
    "activityBarBadge.foreground": "#15202b",
    "commandCenter.border": "#e7e7e799",
    "sash.hoverBorder": "#ff6433",
    "statusBar.background": "#ff3d00",
    "statusBar.foreground": "#e7e7e7",
    "statusBarItem.hoverBackground": "#ff6433",
    "statusBarItem.remoteBackground": "#ff3d00",
    "statusBarItem.remoteForeground": "#e7e7e7",
    "titleBar.activeBackground": "#ff3d00",
    "titleBar.activeForeground": "#e7e7e7",
    "titleBar.inactiveBackground": "#ff3d0099",
    "titleBar.inactiveForeground": "#e7e7e799",
    "folderPathColor.custom1": "#FF4488",
    "folderPathColor.custom2": "#c8e9b5",
    "folderPathColor.custom3": "#4488FF"
  },
  "peacock.remoteColor": "#ff3d00",
  "workbench.iconTheme": "material-icon-theme",
  "material-icon-theme.folders.theme": "specific",
  // 1）给父包染色（精确路径，不递归所有 *）
  "material-icon-theme.folders.associations": {
    "packages/main": "app",
    "packages/renderer": "components"
  },
  "folder-path-color.folders": [
    {
      "path": "packages/**/node_modules",
      "color": "system",
      "symbol": "T",
      "tooltip": "Common"
    },
    {
      "path": "packages/**/dist",
      "color": "system",
      "symbol": "T",
      "tooltip": "Common"
    },
    {
      "path": "packages/**/.*",
      "color": "system",
      "symbol": "T",
      "tooltip": "Common"
    },
    {
      "path": "packages/renderer",
      "color": "blue",
      "symbol": "⚛",
      "tooltip": "Svelte Renderer"
    },
    {
      "path": "packages/main",
      "color": "custom2",
      "symbol": "🧪",
      "tooltip": "Main Process"
    }
  ]
}
